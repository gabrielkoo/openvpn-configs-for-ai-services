client
dev tun
proto udp

# Replace with your OpenVPN server host and port
remote $vpn.server.ip.address $port
server-poll-timeout 20

remote-random
resolv-retry infinite
nobind

# Prevent default routing of all traffic through VPN
route-nopull

# Anthropic Claude
# 160.79.104.0/21 = Anthropic Inc. (AS399230) core. Resolved GCLB front-ends
# (34.36.x) are picked up dynamically each run by scripts/update_ips.py.
# >>> AI-IPS:claude (auto-generated by update_ips.py — do not edit) >>>
route 34.36.57.0 255.255.255.0
route 160.79.104.0 255.255.248.0
route -6 2607:6bc0::/32
# <<< AI-IPS:claude <<<

cipher AES-256-GCM

setenv CLIENT_CERT 0
tun-mtu 1500
mssfix 0
persist-key
persist-tun

reneg-sec 0

remote-cert-tls server
auth-user-pass

<ca>
-----BEGIN CERTIFICATE-----
CERTIFICATE_CONTENTS_HERE
-----END CERTIFICATE-----
</ca>

<tls-crypt>
-----BEGIN OpenVPN Static key V1-----
YOUR_STATIC_KEY_HERE
-----END OpenVPN Static key V1-----
</tls-crypt>
