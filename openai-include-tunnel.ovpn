client
dev tun
proto udp

# Replace with your OpenVPN server host and port
remote $vpn.server.ip.address $port
server-poll-timeout 20

remote-random
resolv-retry infinite
nobind

# Prevent default routing of all traffic through VPN
route-nopull

# OpenAI
# The IP addresses are resolved and simplified into broader CIDR blocks for convenience.
# For a more specific one, use the static list computed by @nugged: https://github.com/gabrielkoo/openvpn-configs-for-ai-services/issues/1
# >>> AI-IPS:openai (auto-generated by update_ips.py — do not edit) >>>
route 104.18.32.0 255.255.254.0
route 104.18.37.0 255.255.255.0
route 104.18.41.0 255.255.255.0
route 162.159.140.0 255.255.255.0
route 172.64.146.0 255.255.255.0
route 172.64.150.0 255.255.255.0
route 172.64.154.0 255.255.254.0
route 172.65.90.0 255.255.255.0
route 172.66.0.0 255.255.255.0
route -6 2606:4700:78::/48
route -6 2606:4700:4400::/48
route -6 2606:4700:4402::/48
route -6 2606:4700:4408::/48
route -6 2a06:98c1:3101::/48
route -6 2a06:98c1:3108::/48
route -6 2a06:98c1:310b::/48
route -6 2a06:98c1:310c::/47
# <<< AI-IPS:openai <<<

cipher AES-256-GCM

setenv CLIENT_CERT 0
tun-mtu 1500
mssfix 0
persist-key
persist-tun

reneg-sec 0

remote-cert-tls server
auth-user-pass

<ca>
-----BEGIN CERTIFICATE-----
CERTIFICATE_CONTENTS_HERE
-----END CERTIFICATE-----
</ca>

<tls-crypt>
-----BEGIN OpenVPN Static key V1-----
YOUR_STATIC_KEY_HERE
-----END OpenVPN Static key V1-----
</tls-crypt>
